{
    "name": "statikbe/laravel-chained-translator",
    "description": "The Laravel Chained Translator can combine several translators that can override each others translations.",
    "license": "MIT",
    "keywords": [
        "statikbe",
        "laravel",
        "statik",
        "translations",
        "customer",
        "content manager",
        "custom",
        "chained",
        "chain"
    ],
    "autoload": {
        "psr-4": {
            "Statikbe\\LaravelChainedTranslator\\": "src/"
        },
        "files": [
            "src/Helpers/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Statikbe\\LaravelChainedTranslator\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Kobe Christiaensen",
            "email": "kobe@statik.be"
        },
        {
            "name": "Sten Govaerts",
            "email": "sten@statik.be"
        },
        {
            "name": "Johan Maes",
            "email": "johan@statik.be"
        },
        {
            "name": "Kayalion"
        }
    ],
    "require": {
        "php": "^8.1|^8.2|^8.3|^8.4",
        "brick/varexporter": "^0.6",
        "laravel/framework": "^9.0|^10.0|^11.0|^12.0"
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Statikbe\\LaravelChainedTranslator\\TranslationServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require-dev": {
        "carthage-software/mago": "^1.13",
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.0|^4.4",
        "pestphp/pest-plugin-laravel": "^3.0|^4.1"
    }
}
